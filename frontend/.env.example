# Verdant Environment Variables
# Copy this file to .env.local and fill in values

# Alchemy RPC — required for Ethereum, Arbitrum, Base, and Solana
ALCHEMY_API_KEY_ETHEREUM=
ALCHEMY_API_KEY_ARBITRUM=
ALCHEMY_API_KEY_BASE=
ALCHEMY_API_KEY_SOLANA=

# Solana RPC — required for Solana execution (client-side)
NEXT_PUBLIC_SOLANA_RPC_URL=

# Zerion API - required for position data
ZERION_API_KEY=

# WalletConnect — required for wallet connection
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# NEAR Intents — required for cross-chain routing (Milestone 2)
NEAR_INTENTS_API_KEY=

# Pendle Hosted SDK — required for Pendle integration (Milestone 3)
PENDLE_HOSTED_SDK_API_KEY=

# Supabase — required for user preferences and history
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Tenderly — optional, for transaction simulation
TENDERLY_ACCESS_KEY=
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
